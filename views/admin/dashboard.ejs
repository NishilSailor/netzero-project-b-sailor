<%- include('../partials/header', { page: '' }) %>

<div class="page-header">
  <h1>Admin Dashboard</h1>
  <p>Welcome back, <%= admin.username %>. &nbsp;<a href="/admin/logout" style="color:var(--gold);">Log Out</a></p>
</div>

<div class="section">

  <div class="admin-nav-links">
    <a href="/admin/dashboard" class="active">Dashboard</a>
    <a href="/admin/policies">Policies</a>
    <a href="/admin/brokers">Brokers</a>
  </div>

  <div class="admin-stat-cards">
    <div class="admin-stat-card">
      <span class="num"><%= quotes.length %></span>
      <span class="lbl">Quote Requests</span>
    </div>
    <div class="admin-stat-card">
      <span class="num"><%= clients.length %></span>
      <span class="lbl">Clients</span>
    </div>
    <div class="admin-stat-card">
      <span class="num"><%= brokers.length %></span>
      <span class="lbl">Brokers</span>
    </div>
    <div class="admin-stat-card">
      <span class="num"><%= quotes.filter(q => q.status === 'SUBMITTED').length %></span>
      <span class="lbl">Pending Reviews</span>
    </div>
  </div>

  <%# QUOTE REQUESTS %>
  <div class="divider"></div>
  <h2 class="section-title">Quote Requests</h2>
  <p class="section-sub"><%= quotes.length %> total requests in the database.</p>

  <div style="overflow-x:auto; margin-bottom:60px;">
    <table class="dash-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Type</th>
          <th>Status</th>
          <th>Submitted</th>
          <th>Update</th>
        </tr>
      </thead>
      <tbody>
        <% quotes.forEach((q, i) => { %>
          <tr>
            <td><%= q.name %></td>
            <td><%= q.email %></td>
            <td><%= q.phone || '—' %></td>
            <td><%= q.insurance_type %></td>
            <td>
              <span class="badge <%=
                q.status === 'SUBMITTED' ? 'badge-gold' :
                q.status === 'IN_REVIEW' ? 'badge-blue' :
                q.status === 'QUOTED'    ? 'badge-green' : 'badge-grey'
              %>"><%= q.status %></span>
            </td>
            <td><%= new Date(q.submitted_at).toLocaleDateString() %></td>
            <td>
              <form action="/admin/quote/status" method="POST" style="display:flex; gap:6px;">
                <input type="hidden" name="id" value="<%= q.id %>" />
                <select name="status" style="padding:5px 8px; border:1px solid #ddd; border-radius:4px; font-size:0.8rem;">
                  <option value="SUBMITTED" <%= q.status === 'SUBMITTED' ? 'selected' : '' %>>Submitted</option>
                  <option value="IN_REVIEW" <%= q.status === 'IN_REVIEW' ? 'selected' : '' %>>In Review</option>
                  <option value="QUOTED"    <%= q.status === 'QUOTED'    ? 'selected' : '' %>>Quoted</option>
                  <option value="CLOSED"    <%= q.status === 'CLOSED'    ? 'selected' : '' %>>Closed</option>
                </select>
                <button type="submit" class="btn btn-sm">Save</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (quotes.length === 0) { %>
          <tr><td colspan="7" style="text-align:center; color:#999; padding:25px;">No quote requests yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <%# CLIENTS %>
  <div class="divider"></div>
  <h2 class="section-title">Registered Clients</h2>
  <p class="section-sub"><%= clients.length %> clients in the system.</p>

  <div style="overflow-x:auto; margin-bottom:40px;">
    <table class="dash-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Broker</th>
          <th>Message</th>
          <th>Delete</th>
        </tr>
      </thead>
      <tbody>
        <% clients.forEach(c => { %>
          <tr>
            <td><strong><%= c.full_name %></strong></td>
            <td><%= c.email %></td>
            <td><%= c.phone || '—' %></td>
            <td><%= c.broker_name || '—' %></td>
            <td>
              <button onclick="openMessageModal(<%= c.id %>, '<%= c.full_name %>')" class="btn btn-sm">
                Message
              </button>
            </td>
            <td>
              <button onclick="confirmDelete(<%= c.id %>, '<%= c.full_name %>')" class="btn btn-sm btn-danger">
                Delete
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%# ADD NEW CLIENT %>
  <div class="divider"></div>
  <h2 class="section-title">Add New Client</h2>
  <p class="section-sub">New clients get a default password of <strong>client123</strong>.</p>

  <div style="background:white; border-radius:12px; padding:35px; box-shadow:0 4px 20px rgba(0,0,0,0.07); max-width:700px;">
    <form action="/admin/client/add" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label>Full Name *</label>
          <input type="text" name="full_name" required placeholder="Jane Smith" />
        </div>
        <div class="form-group">
          <label>Email *</label>
          <input type="email" name="email" required placeholder="jane@email.com" />
        </div>
        <div class="form-group">
          <label>Phone</label>
          <input type="tel" name="phone" placeholder="613-555-0100" />
        </div>
        <div class="form-group">
          <label>Assigned Broker</label>
          <select name="assigned_broker_id">
            <option value="">— None —</option>
            <% brokers.forEach(b => { %>
              <option value="<%= b.id %>"><%= b.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Address</label>
        <input type="text" name="address" placeholder="123 Main St, Kingston, ON" />
      </div>
      <button type="submit" class="btn" style="margin-top:10px;">Add Client</button>
    </form>
  </div>

</div>

<%# MESSAGE MODAL %>
<div class="modal-overlay" id="messageModal">
  <div class="modal-box">
    <h3>Send Message</h3>
    <p class="modal-sub" id="modalClientName"></p>
    <form action="/admin/message/send" method="POST">
      <input type="hidden" name="client_id" id="modalClientId" />
      <input type="hidden" name="broker_id" value="<%= brokers.length > 0 ? brokers[0].id : 1 %>" />
      <div class="form-group">
        <label>Message</label>
        <textarea name="body" required placeholder="Type your message here..."></textarea>
      </div>
      <div class="modal-actions">
        <button type="submit" class="btn">Send</button>
        <button type="button" onclick="closeModal('messageModal')" style="padding:12px 25px; background:#eee; border:none; border-radius:6px; cursor:pointer;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<%# DELETE MODAL %>
<div class="modal-overlay" id="deleteModal">
  <div class="modal-box" style="text-align:center;">
    <div style="font-size:2.5rem; margin-bottom:15px;">⚠️</div>
    <h3>Delete Client?</h3>
    <p class="modal-sub" id="deleteClientName"></p>
    <p style="color:#dc3545; font-size:0.85rem; margin-bottom:20px;">This will also delete all their policies and messages. This cannot be undone.</p>
    <form action="/admin/client/delete" method="POST">
      <input type="hidden" name="id" id="deleteClientId" />
      <div class="modal-actions" style="justify-content:center;">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <button type="button" onclick="closeModal('deleteModal')" style="padding:12px 25px; background:#eee; border:none; border-radius:6px; cursor:pointer;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openMessageModal(id, name) {
    document.getElementById('modalClientId').value = id;
    document.getElementById('modalClientName').textContent = 'To: ' + name;
    document.getElementById('messageModal').classList.add('open');
  }
  function confirmDelete(id, name) {
    document.getElementById('deleteClientId').value = id;
    document.getElementById('deleteClientName').textContent = 'You are about to permanently delete ' + name + ' and all their data.';
    document.getElementById('deleteModal').classList.add('open');
  }
  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }
</script>

<%- include('../partials/footer') %>