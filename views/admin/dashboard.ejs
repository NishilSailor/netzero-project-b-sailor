<%- include('../partials/header', { page: '' }) %>

<div class="page-header">
  <h1>Admin Dashboard</h1>
  <p>Welcome back, <%= admin.username %>. &nbsp;<a href="/admin/logout" style="color:#c8973a;">Log Out</a></p>
</div>

<div class="section">

  <%# QUOTE REQUESTS %>
  <div class="divider"></div>
  <h2 class="section-title">Quote Requests</h2>
  <p class="section-sub"><%= quotes.length %> total requests in the database.</p>

  <div style="overflow-x:auto; margin-bottom: 60px;">
    <table style="width:100%; border-collapse:collapse; background:white; border-radius:8px; overflow:hidden; box-shadow:0 2px 15px rgba(0,0,0,0.07);">
      <thead style="background:#1a2e4a; color:white;">
        <tr>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Name</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Email</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Phone</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Type</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Status</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Submitted</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Update</th>
        </tr>
      </thead>
      <tbody>
        <% quotes.forEach((q, i) => { %>
          <tr style="background:<%= i % 2 === 0 ? '#fff' : '#f8f9fa' %>; border-bottom:1px solid #eee;">
            <td style="padding:12px 16px; font-size:0.9rem;"><%= q.name %></td>
            <td style="padding:12px 16px; font-size:0.9rem;"><%= q.email %></td>
            <td style="padding:12px 16px; font-size:0.9rem;"><%= q.phone || '—' %></td>
            <td style="padding:12px 16px; font-size:0.9rem;"><%= q.insurance_type %></td>
            <td style="padding:12px 16px; font-size:0.9rem; color:#c8973a; font-weight:600;"><%= q.status %></td>
            <td style="padding:12px 16px; font-size:0.9rem;"><%= new Date(q.submitted_at).toLocaleDateString() %></td>
            <td style="padding:12px 16px;">
              <form action="/admin/quote/status" method="POST" style="display:flex; gap:6px;">
                <input type="hidden" name="id" value="<%= q.id %>" />
                <select name="status" style="padding:5px 8px; border:1px solid #ddd; border-radius:4px; font-size:0.8rem;">
                  <option value="SUBMITTED" <%= q.status === 'SUBMITTED' ? 'selected' : '' %>>Submitted</option>
                  <option value="IN_REVIEW" <%= q.status === 'IN_REVIEW' ? 'selected' : '' %>>In Review</option>
                  <option value="QUOTED"    <%= q.status === 'QUOTED'    ? 'selected' : '' %>>Quoted</option>
                  <option value="CLOSED"    <%= q.status === 'CLOSED'    ? 'selected' : '' %>>Closed</option>
                </select>
                <button type="submit" style="padding:5px 12px; background:#1a2e4a; color:white; border:none; border-radius:4px; font-size:0.8rem; cursor:pointer;">Save</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (quotes.length === 0) { %>
          <tr><td colspan="7" style="padding:20px; text-align:center; color:#999;">No quote requests yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <%# CLIENTS %>
  <div class="divider"></div>
  <h2 class="section-title">Registered Clients</h2>
  <p class="section-sub"><%= clients.length %> clients in the system.</p>

  <div style="overflow-x:auto; margin-bottom: 40px;">
    <table style="width:100%; border-collapse:collapse; background:white; border-radius:8px; overflow:hidden; box-shadow:0 2px 15px rgba(0,0,0,0.07);">
      <thead style="background:#1a2e4a; color:white;">
        <tr>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Name</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Email</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Phone</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Broker</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Message</th>
          <th style="padding:12px 16px; text-align:left; font-size:0.85rem;">Delete</th>
        </tr>
      </thead>
      <tbody>
        <% clients.forEach((c, i) => { %>
          <tr style="background:<%= i % 2 === 0 ? '#fff' : '#f8f9fa' %>; border-bottom:1px solid #eee;">
            <td style="padding:12px 16px; font-size:0.9rem;"><%= c.full_name %></td>
            <td style="padding:12px 16px; font-size:0.9rem;"><%= c.email %></td>
            <td style="padding:12px 16px; font-size:0.9rem;"><%= c.phone || '—' %></td>
            <td style="padding:12px 16px; font-size:0.9rem;"><%= c.broker_name || '—' %></td>
            <td style="padding:12px 16px;">
              <button onclick="openMessageModal(<%= c.id %>, '<%= c.full_name %>')"
                style="padding:5px 12px; background:#c8973a; color:white; border:none; border-radius:4px; font-size:0.8rem; cursor:pointer;">
                Message
              </button>
            </td>
            <td style="padding:12px 16px;">
              <button onclick="confirmDelete(<%= c.id %>, '<%= c.full_name %>')"
                style="padding:5px 12px; background:#dc3545; color:white; border:none; border-radius:4px; font-size:0.8rem; cursor:pointer;">
                Delete
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%# ADD NEW CLIENT %>
  <div class="divider"></div>
  <h2 class="section-title">Add New Client</h2>
  <p class="section-sub">New clients are given a default password of <strong>client123</strong> — remind them to contact you to change it.</p>

  <div style="background:white; border-radius:8px; padding:35px; box-shadow:0 2px 15px rgba(0,0,0,0.07); max-width:700px;">
    <form action="/admin/client/add" method="POST">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
        <div class="form-group">
          <label>Full Name *</label>
          <input type="text" name="full_name" required placeholder="Jane Smith" />
        </div>
        <div class="form-group">
          <label>Email *</label>
          <input type="email" name="email" required placeholder="jane@email.com" />
        </div>
        <div class="form-group">
          <label>Phone</label>
          <input type="tel" name="phone" placeholder="613-555-0100" />
        </div>
        <div class="form-group">
          <label>Assigned Broker</label>
          <select name="assigned_broker_id">
            <option value="">— None —</option>
            <% brokers.forEach(b => { %>
              <option value="<%= b.id %>"><%= b.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Address</label>
        <input type="text" name="address" placeholder="123 Main St, Kingston, ON" />
      </div>
      <button type="submit" class="btn" style="margin-top:10px;">Add Client</button>
    </form>
  </div>

</div>

<%# MESSAGE MODAL %>
<div id="messageModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:999; align-items:center; justify-content:center;">
  <div style="background:white; border-radius:8px; padding:35px; width:90%; max-width:500px;">
    <h3 style="color:#1a2e4a; margin-bottom:5px;">Send Message</h3>
    <p id="modalClientName" style="color:#999; font-size:0.9rem; margin-bottom:20px;"></p>
    <form action="/admin/message/send" method="POST">
      <input type="hidden" name="client_id" id="modalClientId" />
      <input type="hidden" name="broker_id" value="<%= brokers.length > 0 ? brokers[0].id : 1 %>" />
      <div class="form-group">
        <label>Message</label>
        <textarea name="body" style="width:100%; padding:12px; border:1px solid #ddd; border-radius:4px; height:120px; font-family:inherit; font-size:0.95rem;" required placeholder="Type your message here..."></textarea>
      </div>
      <div style="display:flex; gap:10px; margin-top:10px;">
        <button type="submit" class="btn">Send</button>
        <button type="button" onclick="closeMessageModal()" style="padding:12px 25px; background:#eee; border:none; border-radius:4px; cursor:pointer;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<%# DELETE CONFIRM MODAL %>
<div id="deleteModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:999; align-items:center; justify-content:center;">
  <div style="background:white; border-radius:8px; padding:35px; width:90%; max-width:420px; text-align:center;">
    <div style="font-size:2.5rem; margin-bottom:15px;">⚠️</div>
    <h3 style="color:#1a2e4a; margin-bottom:10px;">Delete Client?</h3>
    <p id="deleteClientName" style="color:#666; margin-bottom:25px; font-size:0.95rem;"></p>
    <p style="color:#dc3545; font-size:0.85rem; margin-bottom:25px;">This will also delete all their policies and messages. This cannot be undone.</p>
    <form action="/admin/client/delete" method="POST">
      <input type="hidden" name="id" id="deleteClientId" />
      <div style="display:flex; gap:10px; justify-content:center;">
        <button type="submit" style="padding:12px 25px; background:#dc3545; color:white; border:none; border-radius:4px; cursor:pointer; font-weight:600;">Yes, Delete</button>
        <button type="button" onclick="closeDeleteModal()" style="padding:12px 25px; background:#eee; border:none; border-radius:4px; cursor:pointer;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openMessageModal(id, name) {
    document.getElementById('modalClientId').value = id;
    document.getElementById('modalClientName').textContent = 'To: ' + name;
    document.getElementById('messageModal').style.display = 'flex';
  }
  function closeMessageModal() {
    document.getElementById('messageModal').style.display = 'none';
  }
  function confirmDelete(id, name) {
    document.getElementById('deleteClientId').value = id;
    document.getElementById('deleteClientName').textContent = 'You are about to delete ' + name + ' and all their data.';
    document.getElementById('deleteModal').style.display = 'flex';
  }
  function closeDeleteModal() {
    document.getElementById('deleteModal').style.display = 'none';
  }
</script>

<%- include('../partials/footer') %>