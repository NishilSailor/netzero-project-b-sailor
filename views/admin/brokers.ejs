<%- include('../partials/header', { page: '' }) %>

<div class="page-header">
  <h1>Manage Brokers</h1>
  <p>Admin Panel &nbsp;·&nbsp; <a href="/admin/logout" style="color:var(--gold);">Log Out</a></p>
</div>

<div class="section">

  <div class="admin-nav-links">
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/policies">Policies</a>
    <a href="/admin/brokers" class="active">Brokers</a>
  </div>

  <%# ADD BROKER FORM %>
  <div class="divider"></div>
  <h2 class="section-title">Add a Broker</h2>

  <div style="background:white; border-radius:12px; padding:35px; box-shadow:0 4px 20px rgba(0,0,0,0.07); max-width:600px; margin-bottom:55px;">
    <form action="/admin/broker/add" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" required placeholder="Jane Smith" />
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required placeholder="jane@bsmw.ca" />
        </div>
      </div>
      <div class="form-group">
        <label>Specialization</label>
        <input type="text" name="specialization" placeholder="e.g. Home & Auto, Commercial, Life & Health" />
      </div>
      <button type="submit" class="btn">Add Broker</button>
    </form>
  </div>

  <%# BROKERS TABLE %>
  <div class="divider"></div>
  <h2 class="section-title">All Brokers</h2>
  <p class="section-sub"><%= brokers.length %> brokers on the team.</p>

  <div style="overflow-x:auto;">
    <table class="dash-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Specialization</th>
          <th>Clients</th>
          <th>Delete</th>
        </tr>
      </thead>
      <tbody>
        <% brokers.forEach(b => { %>
          <tr>
            <td><strong><%= b.name %></strong></td>
            <td><%= b.email %></td>
            <td><%= b.specialization || '—' %></td>
            <td><%= b.client_count %></td>
            <td>
              <% if (b.client_count > 0) { %>
                <span style="color:#aaa; font-size:0.8rem;">Reassign clients first</span>
              <% } else { %>
                <form action="/admin/broker/delete" method="POST"
                  onsubmit="return confirm('Delete broker <%= b.name %>?')">
                  <input type="hidden" name="id" value="<%= b.id %>" />
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
        <% if (brokers.length === 0) { %>
          <tr><td colspan="5" style="text-align:center; color:#999; padding:25px;">No brokers found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<%- include('../partials/footer') %>