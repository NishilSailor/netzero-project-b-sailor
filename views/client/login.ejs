<%- include('../partials/header', { page: '' }) %>

<div class="page-header">
  <h1>Client Portal</h1>
  <p>Log in to view your policies and messages.</p>
</div>

<div class="section">
  <div class="form-wrapper" style="max-width: 450px;">

    <% if (error) { %>
      <div class="alert alert-error">Invalid email or password. Please try again.</div>
    <% } %>

    <form action="/client/login" method="POST">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" required placeholder="you@email.com" />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="••••••••" />
      </div>
      <button type="submit" class="btn" style="width:100%; padding: 14px;">Log In</button>
    </form>

    <p style="margin-top:20px; font-size:0.85rem; color:#999; text-align:center;">
      Don't have an account? <a href="/quote" style="color:#c8973a;">Request a quote</a> and your broker will set one up for you.
    </p>

  </div>
</div>

<%- include('../partials/footer') %>