<%- include('../partials/header', { page: 'client' }) %>

<div class="page-header">
  <h1>Welcome, <%= client.name %></h1>
  <p>Your personal insurance portal. &nbsp;<a href="/client/logout" style="color:var(--gold);">Log Out</a></p>
</div>

<div class="section">

  <%# RENEWAL ALERT %>
  <%
    const today = new Date();
    const soonPolicies = policies.filter(p => {
      const renewal = new Date(p.renewal_date);
      const diff = (renewal - today) / (1000 * 60 * 60 * 24);
      return diff >= 0 && diff <= 30;
    });
  %>
  <% if (soonPolicies.length > 0) { %>
    <div class="alert alert-warning" style="margin-bottom:30px;">
      <strong>⚠️ Upcoming Renewal</strong>
      <% soonPolicies.forEach(p => { %>
        <p style="margin:6px 0 0; font-size:0.95rem;">
          Your <strong><%= p.policy_type %></strong> policy renews on
          <strong><%= new Date(p.renewal_date).toLocaleDateString('en-CA', { year:'numeric', month:'long', day:'numeric' }) %></strong>.
          Contact your broker if you have any questions.
        </p>
      <% }) %>
    </div>
  <% } %>

  <%# BROKER INFO %>
  <% if (broker) { %>
    <div class="broker-info-box">
      <div class="broker-avatar"><%= broker.name.split(' ').map(n => n[0]).join('') %></div>
      <div>
        <h4>Your Assigned Broker</h4>
        <p><strong style="color:white;"><%= broker.name %></strong></p>
        <p>Specialization: <%= broker.specialization || 'General Insurance' %></p>
        <p class="gold">📧 <%= broker.email %> &nbsp;·&nbsp; 📞 (613) 887-2625</p>
      </div>
    </div>
  <% } %>

  <%# POLICIES %>
  <div class="divider"></div>
  <h2 class="section-title">Your Active Policies</h2>
  <p class="section-sub">All your current coverage in one place.</p>

  <div class="cards" style="margin-bottom:50px;">
    <% if (policies.length === 0) { %>
      <p style="color:#999;">No policies on file yet. Contact your broker for more information.</p>
    <% } %>
    <% policies.forEach(p => { %>
      <div class="card fade-up">
        <span class="card-icon">📋</span>
        <h3><%= p.policy_type %></h3>
        <p><strong>Insurer:</strong> <%= p.insurer %></p>
        <p><strong>Premium:</strong> $<%= parseFloat(p.premium).toFixed(2) %>/yr</p>
        <p><strong>Renewal:</strong> <%= new Date(p.renewal_date).toLocaleDateString('en-CA', { year:'numeric', month:'long', day:'numeric' }) %></p>
        <p style="margin-top:12px;">
          <span class="badge <%= p.status === 'ACTIVE' ? 'badge-green' : 'badge-red' %>">
            <%= p.status %>
          </span>
        </p>
      </div>
    <% }) %>
  </div>

  <%# MESSAGES %>
  <div class="divider"></div>
  <h2 class="section-title">Messages</h2>
  <p class="section-sub">Your conversation with your broker.</p>

  <% if (messages.length === 0) { %>
    <p style="color:#999; margin-bottom:30px;">No messages yet.</p>
  <% } %>

  <% messages.forEach(m => { %>
    <div style="background:white; border-radius:10px; padding:20px 25px; margin-bottom:15px; box-shadow:0 2px 12px rgba(0,0,0,0.06); border-left:4px solid var(--gold);">
      <p style="font-size:0.8rem; color:#aaa; margin-bottom:8px;">
        <%= m.broker_name %> &nbsp;·&nbsp; <%= new Date(m.sent_at).toLocaleString() %>
      </p>
      <p style="color:#333; line-height:1.7;"><%= m.body %></p>
    </div>
  <% }) %>

  <%# MESSAGE FORM %>
  <div style="background:white; border-radius:12px; padding:30px; margin-top:30px; box-shadow:0 4px 20px rgba(0,0,0,0.07);">
    <h3 style="color:var(--navy); margin-bottom:6px;">Send a Message to Your Broker</h3>
    <p style="color:#aaa; font-size:0.85rem; margin-bottom:20px;">We typically respond within one business day.</p>
    <form action="/client/message/send" method="POST">
      <div class="form-group">
        <textarea name="body" required placeholder="Hi, I have a question about my renewal..." style="width:100%; padding:13px 16px; border:2px solid #e8ecf0; border-radius:6px; height:110px; font-family:inherit; font-size:0.95rem;"></textarea>
      </div>
      <button type="submit" class="btn">Send Message</button>
    </form>
  </div>

</div>

<%- include('../partials/footer') %>